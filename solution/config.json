{
  "provider": "openai",
  "model": "gpt-4o-mini",
  "model_price_tier": "budget",
  "max_steps": 8,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 4,
  "verbose_system": false,
  "timeout_ms": 15000,
  "max_completion_tokens": 1000,
  "retry": {
    "enabled": true,
    "max_attempts": 3,
    "backoff_ms": 200
  },
  "cache": {
    "enabled": true
  },
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 6,
  "tool_error_rate": 0.0,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": true,
  "self_consistency": 2,
  "tool_budget": 4
}